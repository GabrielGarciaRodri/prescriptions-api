# Base de datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prescriptions?schema=public"

# JWT - generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="Hola_Soy_Un_Secreto_Para_Acceso_Cambiar_en_prod-min-32-chars"
JWT_REFRESH_SECRET="Hola_Soy_Un_Secreto_Para_Refresh_Cambiar_en_prod-min-32-chars"
JWT_ACCESS_TTL="900"
JWT_REFRESH_TTL="604800"

# CORS: dominios permitidos separados por coma, o "*" para permitir todos
APP_ORIGIN="http://localhost:3001"

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development
